#: src/core/org.freedesktop.systemd1.policy.in:22
msgid "Send passphrase back to system"
msgstr "پارولنى سىستېمىغا قايتا ئەۋەتىڭ"

#: src/core/org.freedesktop.systemd1.policy.in:23
msgid "Authentication is required to send the entered passphrase back to the system."
msgstr "كىرگۈزۈلگەن پارولنى سىستېمىغا قايتۇرۇش ئۈچۈن دەلىللەش تەلەپ قىلىنىدۇ."

#: src/core/org.freedesktop.systemd1.policy.in:33
msgid "Manage system services or other units"
msgstr "باشقۇرۇش سىستېمىسى مۇلازىمىتى ياكى باشقا ئورۇنلار"

#: src/core/org.freedesktop.systemd1.policy.in:34
msgid "Authentication is required to manage system services or other units."
msgstr "باشقۇرۇش سىستېمىسى مۇلازىمىتى ياكى باشقا ئورۇنلارغا گۇۋاھنامە تەلەپ قىلىنىدۇ."

#: src/core/org.freedesktop.systemd1.policy.in:43
msgid "Manage system service or unit files"
msgstr "باشقۇرۇش سىستېمىسى مۇلازىمىتى ياكى بىرلىك ھۆججىتى"

#: src/core/org.freedesktop.systemd1.policy.in:44
msgid "Authentication is required to manage system service or unit files."
msgstr "باشقۇرۇش سىستېمىسى مۇلازىمىتى ياكى ئورۇن ھۆججىتى دەلىللەشنى تەلەپ قىلىدۇ."

#: src/core/org.freedesktop.systemd1.policy.in:54
msgid "Set or unset system and service manager environment variables"
msgstr "سىستېما ۋە مۇلازىمەت باشقۇرغۇچىنىڭ مۇھىت ئۆزگەرگۈچى مىقدارلىرىنى تەڭشەش ياكى تازىلاش"

#: src/core/org.freedesktop.systemd1.policy.in:55
msgid "Authentication is required to set or unset system and service manager environment variables."
msgstr "سىستېما ۋە مۇلازىمەت باشقۇرغۇچىنىڭ مۇھىت ئۆزگەرگۈچى مىقدارلىرىنى تەڭشەش ياكى تازىلاش تەلەپ قىلىنىدۇ."

#: src/core/org.freedesktop.systemd1.policy.in:64
msgid "Reload the systemd state"
msgstr "سىستېما ھالىتىنى قايتا يۈكلەڭ"

#: src/core/org.freedesktop.systemd1.policy.in:65
msgid "Authentication is required to reload the systemd state."
msgstr "سىستېما ھالىتىنى قايتا يۈكلەش دەلىللەشنى تەلەپ قىلىدۇ."

#: src/core/org.freedesktop.systemd1.policy.in:74
msgid "Dump the systemd state without rate limits"
msgstr "ئۆسۈم چەكلىمىسىسىز تۆكمە قىلىپ تاشلاش  systemd دۆلەت"

#: src/core/org.freedesktop.systemd1.policy.in:75
msgid "Authentication is required to dump the systemd state without rate limits."
msgstr "چەكلىمىسىز تۆكمە قىلىپ سېتىش systemd ھالەت دەلىللەشنى تەلەپ قىلىدۇ."

#: src/home/org.freedesktop.home1.policy:13
msgid "Create a home area"
msgstr "ئائىلە رايونى قۇرۇش"

#: src/home/org.freedesktop.home1.policy:14
msgid "Authentication is required to create a user's home area."
msgstr "ئىشلەتكۈچىنىڭ ئائىلە رايونى قۇرۇش ئۈچۈن دەلىللەش تەلەپ قىلىنىدۇ."

#: src/home/org.freedesktop.home1.policy:23
msgid "Remove a home area"
msgstr "ئۆي رايونىنى ئېلىۋېتىڭ"

#: src/home/org.freedesktop.home1.policy:24
msgid "Authentication is required to remove a user's home area."
msgstr "ئىشلەتكۈچىنىڭ ئائىلە رايونىنى ئېلىۋېتىش دەلىللەشنى تەلەپ قىلىدۇ."

#: src/home/org.freedesktop.home1.policy:33
msgid "Check credentials of a home area"
msgstr "تەكشۈرگۈچى رايون تالونى"

#: src/home/org.freedesktop.home1.policy:34
msgid "Authentication is required to check credentials against a user's home area."
msgstr "تالونلارنى ئىشلەتكۈچىنىڭ ئۆيىگە ئاساسەن تەكشۈرۈش ئۈچۈن گۇۋاھنامە تەلەپ قىلىنىدۇ."

#: src/home/org.freedesktop.home1.policy:43
msgid "Update a home area"
msgstr "ئۆي رايونىنى يېڭىلاڭ"

# Pay attention to the concept of "seat".
#
# To fully understand the meaning, please refer to session management in old ConsoleKit and new systemd-logind.
#: src/home/org.freedesktop.home1.policy:44
msgid "Authentication is required to update a user's home area."
msgstr "ئىشلەتكۈچىنىڭ ئائىلە رايونىنى يېڭىلاش ئۈچۈن دەلىللەش تەلەپ قىلىنىدۇ."

#: src/home/org.freedesktop.home1.policy:53
msgid "Resize a home area"
msgstr "ئۆي كۆلىمىنىڭ چوڭ-كىچىكلىكىنى تەڭشەڭ"

#: src/home/org.freedesktop.home1.policy:54
msgid "Authentication is required to resize a user's home area."
msgstr "ئۆي كۆلىمىنىڭ چوڭ-كىچىكلىكىنى تەڭشەش گۇۋاھنامە تەلەپ قىلىدۇ."

#: src/home/org.freedesktop.home1.policy:63
msgid "Change password of a home area"
msgstr "ئۆيىڭىزنىڭ پارولىنى ئۆزگەرتىڭ"

#: src/home/org.freedesktop.home1.policy:64
msgid "Authentication is required to change the password of a user's home area."
msgstr "ئائىلە رايونىنىڭ پارولىنى ئۆزگەرتىش ئۈچۈن دەلىللەش تەلەپ قىلىنىدۇ."

#: src/home/pam_systemd_home.c:287
#, c-format
msgid "Home of user %s is currently absent, please plug in the necessary storage device or backing file system."
msgstr "ئىشلەتكۈچى %s نىڭ ئۆيى ھازىر يوق، زۆرۈر ساقلاش ئۈسكۈنىسى ياكى ئارقا ھۆججەت سىستېمىسىغا قىستۇرۇڭ."

#: src/home/pam_systemd_home.c:292
#, c-format
msgid "Too frequent login attempts for user %s, try again later."
msgstr "ئىشلەتكۈچى %s كىرىش سىنىقى بەك كۆپ بولۇپ، كېيىن قايتا سىناپ بېقىڭ."

#: src/home/pam_systemd_home.c:304
msgid "Password: "
msgstr "پارول： "

#: src/home/pam_systemd_home.c:306
#, c-format
msgid "Password incorrect or not sufficient for authentication of user %s."
msgstr "ئىشلەتكۈچى %s پارول خاتا ياكى دەلىللەشنى تاماملاشقا يەتمەيدۇ."

#: src/home/pam_systemd_home.c:307
msgid "Sorry, try again: "
msgstr "كەچۈرۈڭ، قايتا سىناپ بېقىڭ： "

#: src/home/pam_systemd_home.c:329
msgid "Recovery key: "
msgstr "ئەسلىگە كەلتۈرۈش ئاچقۇچى： "

#: src/home/pam_systemd_home.c:331
#, c-format
msgid "Password/recovery key incorrect or not sufficient for authentication of user %s."
msgstr "ئىشلەتكۈچى %s پارول/ئەسلىگە كەلتۈرۈش ئاچقۇچى خاتا ياكى دەلىللەشنى تاماملاشقا يەتمەيدۇ."

#: src/home/pam_systemd_home.c:332
msgid "Sorry, reenter recovery key: "
msgstr "كەچۈرۈڭ، ئەسلىگە كەلتۈرۈش ئاچقۇچىغا قايتا كىرىڭ： "

#: src/home/pam_systemd_home.c:352
#, c-format
msgid "Security token of user %s not inserted."
msgstr "ئىشلەتكۈچى%s نىڭ بىخەتەرلىك بەلگىسى قىستۇرۇلمايدۇ."

#: src/home/pam_systemd_home.c:353 src/home/pam_systemd_home.c:356
msgid "Try again with password: "
msgstr "پارول بىلەن قايتا سىناپ بېقىڭ："

#: src/home/pam_systemd_home.c:355
#, c-format
msgid "Password incorrect or not sufficient, and configured security token of user %s not inserted."
msgstr "پارول خاتا ياكى ئىناۋەتسىز，ئىشلەتكۈچى %s سەپلىمە بىخەتەرلىك بەلگىسى قىستۇرۇلمىغان"

#: src/home/pam_systemd_home.c:376
msgid "Security token PIN: "
msgstr "بىخەتەرلىك توكەن PIN： "

#: src/home/pam_systemd_home.c:393
#, c-format
msgid "Please authenticate physically on security token of user %s."
msgstr "ئىشلەتكۈچىدە ئۆتۈنۈڭ %s بىخەتەرلىك بەلگىسىدىكى فىزىكىلىق دەلىللەش."

#: src/home/pam_systemd_home.c:404
#, c-format
msgid "Please confirm presence on security token of user %s."
msgstr "بىخەتەرلىك بەلگىسىدە ئىشلەتكۈچىنىڭ بارلىقىنى جەزملەشتۈرۈڭ %s。"

#: src/home/pam_systemd_home.c:415
#, c-format
msgid "Please verify user on security token of user %s."
msgstr "ئىشلەتكۈچىنىڭ بىخەتەرلىك بەلگىسىدىكى ئىشلەتكۈچىنى تەكشۈرۈپ بېقىڭ %s"

#: src/home/pam_systemd_home.c:424
msgid "Security token PIN is locked, please unlock it first. (Hint: Removal and re-insertion might suffice.)"
msgstr "بىخەتەرلىك بەلگىسى PIN قۇلۇپلانغان، ئالدى بىلەن ئۇنى ئېچىڭ. (Hint: ئېلىۋېتىش ۋە قايتا قىستۇرۇش يېتەرلىك بولۇشى مۇمكىن.)"

#: src/home/pam_systemd_home.c:432
#, c-format
msgid "Security token PIN incorrect for user %s."
msgstr "بىخەتەرلىك بەلگىسى PIN ئىشلەتكۈچىگە خاتا %s"

#: src/home/pam_systemd_home.c:433 src/home/pam_systemd_home.c:452
#: src/home/pam_systemd_home.c:471
msgid "Sorry, retry security token PIN: "
msgstr "كەچۈرۈڭ، بىخەتەرلىك بەلگىسى PIN نى قايتا سىناپ بېقىڭ:  "

#: src/home/pam_systemd_home.c:451
#, c-format
msgid "Security token PIN of user %s incorrect (only a few tries left!)"
msgstr "ئىشلەتكۈچى %s بىخەتەرلىك بەلگىسى PIN (پەقەت بىر قانچە قايتا ئوقۇش پۇرسىتى قالدى!)"

#: src/home/pam_systemd_home.c:470
#, c-format
msgid "Security token PIN of user %s incorrect (only one try left!)"
msgstr "ئىشلەتكۈچى %s بىخەتەرلىك بەلگىسى PIN توغرا ئەمەس (پەقەت بىرلا قېتىم قايتا ئوقۇش پۇرسىتى قالدى!)"

#: src/home/pam_systemd_home.c:616
#, c-format
msgid "Home of user %s is currently not active, please log in locally first."
msgstr "ئىشلەتكۈچى%s نىڭ ئائىلە مۇندەرىجىسى ھازىرچە قوزغىتىلمىدى، ئالدى بىلەن يەرلىككە كىرىڭ."

#: src/home/pam_systemd_home.c:618
#, c-format
msgid "Home of user %s is currently locked, please unlock locally first."
msgstr "ئىشلەتكۈچى%s نىڭ ئائىلە مۇندەرىجىسى ھازىر قۇلۇپلانغان، ئالدى بىلەن يەرلىكنى ئېچىڭ."

#: src/home/pam_systemd_home.c:645
#, c-format
msgid "Too many unsuccessful login attempts for user %s, refusing."
msgstr "ئىشلەتكۈچى %s مۇۋەپپەقىيەتلىك كىرىش سىنىقى بەك كۆپ بولۇپ، كىرىش رەت قىلىنغان."

#: src/home/pam_systemd_home.c:868
msgid "User record is blocked, prohibiting access."
msgstr "ئىشلەتكۈچى خاتىرىلىرى توسۇلۇپ قالدى، زىيارەت قىلىش مەنئى قىلىندى."

#: src/home/pam_systemd_home.c:872
msgid "User record is not valid yet, prohibiting access."
msgstr "ئىشلەتكۈچى خاتىرىلىرى تېخى كۈچكە ئىگە ئەمەس، زىيارەت قىلىش مەنئى قىلىنىدۇ."

#: src/home/pam_systemd_home.c:876
msgid "User record is not valid anymore, prohibiting access."
msgstr "ئىشلەتكۈچى خاتىرىلىرى ئەمدى كۈچكە ئىگە ئەمەس، زىيارەت قىلىش مەنئى قىلىنىدۇ."

#: src/home/pam_systemd_home.c:881 src/home/pam_systemd_home.c:932
msgid "User record not valid, prohibiting access."
msgstr "ئىناۋەتسىز ئىشلەتكۈچى خاتىرىسى، زىيارەت قىلىش مەنئى قىلىنىدۇ."

#: src/home/pam_systemd_home.c:893
#, c-format
msgid "Too many logins, try again in %s."
msgstr "كىرىش تەلىپى بەك كۆپ，%s قايتا سىناپ بېقىڭ."

#: src/home/pam_systemd_home.c:904
msgid "Password change required."
msgstr "پارولنى ئۆزگەرتىش كېرەك."

#: src/home/pam_systemd_home.c:908
msgid "Password expired, change required."
msgstr "پارولنىڭ ۋاقتى توشتى، چوقۇم ئۆزگەرتىش كېرەك."

#: src/home/pam_systemd_home.c:914
msgid "Password is expired, but can't change, refusing login."
msgstr "پارولنىڭ ۋاقتى توشتى، ئەمما ئۆزگەرتكىلى بولمايدۇ، كىرىشنى رەت قىلىڭ."

#: src/home/pam_systemd_home.c:918
msgid "Password will expire soon, please change."
msgstr "پارولنىڭ ۋاقتى قىسقا بولىدۇ، ۋاقتىدا ئۆزگەرتىڭ."

#: src/hostname/org.freedesktop.hostname1.policy:20
msgid "Set hostname"
msgstr "باش ئاپپارات نامىنى بەلگىلەڭ"

#: src/hostname/org.freedesktop.hostname1.policy:21
msgid "Authentication is required to set the local hostname."
msgstr "يەرلىك ساھىبجامال نامىنى تەڭشەش دەلىللەشنى تەلەپ قىلىدۇ."

#: src/hostname/org.freedesktop.hostname1.policy:30
msgid "Set static hostname"
msgstr "تۇراقلىق باش ئاپپارات"

# For pretty hostname, the zh_CN/zh_TW translation should be discussed again.
#
# There were some discussions, like https://lists.fedoraprojects.org/pipermail/trans-zh_cn/2012-December/001347.html
#: src/hostname/org.freedesktop.hostname1.policy:31
msgid "Authentication is required to set the statically configured local hostname, as well as the pretty hostname."
msgstr "تۇراقلىق يەرلىك ساھىبجامال ياكى ئېستېتىك ساھىبجامال بەلگىلەش دەلىللەشنى تەلەپ قىلىدۇ."

#: src/hostname/org.freedesktop.hostname1.policy:41
msgid "Set machine information"
msgstr "ماشىنا ئۇچۇرلىرىنى بەلگىلەڭ"

#: src/hostname/org.freedesktop.hostname1.policy:42
msgid "Authentication is required to set local machine information."
msgstr "يەرلىك ماشىنا ئۇچۇرلىرىنى ئورنىتىش ئۈچۈن دەلىللەش تەلەپ قىلىنىدۇ."

#: src/hostname/org.freedesktop.hostname1.policy:51
msgid "Get product UUID"
msgstr "مەھسۇلات UUID غا ئېرىشىڭ"

#: src/hostname/org.freedesktop.hostname1.policy:52
msgid "Authentication is required to get product UUID."
msgstr "UUID مەھسۇلاتىغا ئېرىشىش ئۈچۈن گۇۋاھنامە تەلەپ قىلىنىدۇ."

#: src/hostname/org.freedesktop.hostname1.policy:61
msgid "Get hardware serial number"
msgstr "قاتتىق دېتال تەرتىپ نومۇرىغا ئېرىشىڭ"

#: src/hostname/org.freedesktop.hostname1.policy:62
msgid "Authentication is required to get hardware serial number."
msgstr "قاتتىق دېتال رەت نومۇرىغا ئېرىشىش ئۈچۈن دەلىللەش تەلەپ قىلىنىدۇ."

#: src/hostname/org.freedesktop.hostname1.policy:71
msgid "Get system description"
msgstr "سىستېما چۈشەندۈرۈشىگە ئېرىشىڭ"

#: src/hostname/org.freedesktop.hostname1.policy:72
msgid "Authentication is required to get system description."
msgstr "سىستېما چۈشەندۈرۈشىگە ئېرىشىش ئۈچۈن گۇۋاھنامە تەلەپ قىلىنىدۇ."

#: src/import/org.freedesktop.import1.policy:22
msgid "Import a VM or container image"
msgstr "مەۋھۇم ماشىنا ياكى قاچا سۈرىتىنى ئەكىرىش"

#: src/import/org.freedesktop.import1.policy:23
msgid "Authentication is required to import a VM or container image"
msgstr "مەۋھۇم ماشىنا ياكى قاچا رەسىملىرىنى ئىمپورت قىلىش ئۈچۈن دەلىللەش تەلەپ قىلىنىدۇ"

#: src/import/org.freedesktop.import1.policy:32
msgid "Export a VM or container image"
msgstr "مەۋھۇم ماشىنا ياكى قاچا سۈرىتىنى ئېكسپورت قىلىڭ"

#: src/import/org.freedesktop.import1.policy:33
msgid "Authentication is required to export a VM or container image"
msgstr "مەۋھۇم ماشىنا ياكى قاچا رەسىملىرىنى ئېكسپورت قىلىش ئۈچۈن دەلىللەش تەلەپ قىلىنىدۇ"

#: src/import/org.freedesktop.import1.policy:42
msgid "Download a VM or container image"
msgstr "مەۋھۇم ماشىنا ياكى قاچا ئەينىكىنى چۈشۈرۈڭ"

#: src/import/org.freedesktop.import1.policy:43
msgid "Authentication is required to download a VM or container image"
msgstr "مەۋھۇم ماشىنا ياكى قاچا ئەينىكىنى چۈشۈرۈش ئۈچۈن دەلىللەش تەلەپ قىلىنىدۇ"

#: src/locale/org.freedesktop.locale1.policy:22
msgid "Set system locale"
msgstr "سىستېما رايونى ۋە تىلىنى بەلگىلەڭ"

#: src/locale/org.freedesktop.locale1.policy:23
msgid "Authentication is required to set the system locale."
msgstr "سىستېما رايونى ۋە تىلىنى تەڭشەش دەلىللەشنى تەلەپ قىلىدۇ."

#: src/locale/org.freedesktop.locale1.policy:33
msgid "Set system keyboard settings"
msgstr "سىستېما كۇنۇپكا تاختىسىنى تەڭشەش"

#: src/locale/org.freedesktop.locale1.policy:34
msgid "Authentication is required to set the system keyboard settings."
msgstr "سىستېما كۇنۇپكا تاختىسىنى ئورنىتىش ئۈچۈن دەلىللەش تەلەپ قىلىنىدۇ."

#: src/login/org.freedesktop.login1.policy:22
msgid "Allow applications to inhibit system shutdown"
msgstr "سىستېمىنىڭ تاقىلىشىنىڭ ئالدىنى ئېلىش ئۈچۈن قوللىنىشچان پروگراممىلارغا يول قويۇڭ"

#: src/login/org.freedesktop.login1.policy:23
msgid "Authentication is required for an application to inhibit system shutdown."
msgstr "سىستېمىنىڭ تاقىلىپ قېلىشىنىڭ ئالدىنى ئېلىش ئۈچۈن قوللىنىشچان پروگراممىلارغا رۇخسەت قىلىش دەلىللەشنى تەلەپ قىلىدۇ."

#: src/login/org.freedesktop.login1.policy:33
msgid "Allow applications to delay system shutdown"
msgstr "قوللىنىشچان پروگراممىلارنىڭ سىستېمىنى تاقاشنى كېچىكتۈرۈشىگە يول قويىدۇ"

#: src/login/org.freedesktop.login1.policy:34
msgid "Authentication is required for an application to delay system shutdown."
